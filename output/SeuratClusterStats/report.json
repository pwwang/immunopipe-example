  "Clustree plots": {
    "#": {
      "#": {
        "flat": [
          {
            "kind": "descr",
            "content": "The clustree plots displays clustering results from the Seurat object across different\n                resolutions of the clustering algorithm\n                (<a target=\"_blank\" href=\"https://satijalab.org/seurat/reference/findclusters\">Seurat::FindClusters<\/a>).\n                Each node represents a cluster, with the resolution levels labeled along the vertical (y) axis.\n                The size of each node reflects the number of cells in that cluster. Edges connect clusters between\n                adjacent resolutions and indicate how cells transition between clusters as resolution increases.\n                The thickness of the edges corresponds to the proportion of shared cells (in_prop) between clusters,\n                where darker lines signify a higher overlap (up to 100%). The color of the edges indicates the actual\n                number of cells that transitioned between clusters."
          }
        ],
        "table_of_images": [
          {
            "kind": "image",
            "src": "/mnt/disks/.cwd/output/SeuratClusterStats/samples.scRep.tcr_clustered.tessa.cluster_stats/clustrees/seurat_clusters.clustree.png",
            "descr": "Resolutions: 0.8; resolution used: 0.8"
          }
        ]
      }
    }
  },
